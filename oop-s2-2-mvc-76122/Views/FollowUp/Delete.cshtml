@model oop_s2_2_mvc_76122.Models.FollowUp
@{
    ViewData["Title"] = "Delete Follow-up";
}

<h1>Delete Follow-up</h1>

<div class="alert alert-danger">
    <h3>Are you sure you want to delete this?</h3>
</div>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Inspection
        </dt>
        <dd class="col-sm-10">
            Inspection #@Model.Inspection?.Id - @Model.Inspection?.Premises?.Name
        </dd>
        <dt class="col-sm-2">
            Due Date
        </dt>
        <dd class="col-sm-10">
            @Model.DueDate.ToShortDateString()
        </dd>
        <dt class="col-sm-2">
            Status
        </dt>
        <dd class="col-sm-10">
            @Model.Status
        </dd>
        <dt class="col-sm-2">
            Closed Date
        </dt>
        <dd class="col-sm-10">
            @(Model.ClosedDate?.ToShortDateString() ?? "N/A")
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
