@model IEnumerable<oop_s2_2_mvc_76122.Models.Premises>
@{
    ViewData["Title"] = "Premises";
}

@if (!User.IsInRole("Admin"))
{
    <div class="alert alert-danger">
        <h3>Access Denied</h3>
        <p>You do not have permission to access this resource.</p>
    </div>
}
else
{
    <h1>Premises</h1>

    @if (User.IsInRole("Admin"))
    {
        <p>
            <a asp-action="Create" class="btn btn-primary">Create New Premises</a>
        </p>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Address</th>
                <th>Town</th>
                <th>Risk Rating</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Address</td>
                    <td>@item.Town</td>
                    <td>
                        @if (item.RiskRating.ToString() == "High")
                        {
                            <span class="badge bg-danger">@item.RiskRating</span>
                        }
                        else if (item.RiskRating.ToString() == "Medium")
                        {
                            <span class="badge bg-warning">@item.RiskRating</span>
                        }
                        else
                        {
                            <span class="badge bg-success">@item.RiskRating</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
