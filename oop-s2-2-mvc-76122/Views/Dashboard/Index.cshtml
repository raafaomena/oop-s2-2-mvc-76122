@model oop_s2_2_mvc_76122.Models.DashboardViewModel

<h2>Dashboard</h2>

<form method="get">
    <label>Town:</label>
    <input type="text" name="town" value="@Model.SelectedTown" />

    <label>Risk:</label>
    <input type="text" name="risk" value="@Model.SelectedRisk" />

    <button type="submit">Filter</button>
</form>

<hr />

<div>
    <h3>Inspections This Month: @Model.InspectionsThisMonth</h3>
    <h3>Failed Inspections: @Model.FailedInspections</h3>
    <h3>Overdue Follow-Ups: @Model.OverdueFollowUps</h3>
</div>