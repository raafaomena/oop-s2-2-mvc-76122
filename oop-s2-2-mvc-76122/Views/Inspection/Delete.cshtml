@model oop_s2_2_mvc_76122.Models.Inspection
@{
    ViewData["Title"] = "Delete Inspection";
}

<h1>Delete Inspection</h1>

<div class="alert alert-danger">
    <h3>Are you sure you want to delete this?</h3>
</div>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Premises
        </dt>
        <dd class="col-sm-10">
            @Model.Premises?.Name
        </dd>
        <dt class="col-sm-2">
            Inspection Date
        </dt>
        <dd class="col-sm-10">
            @Model.InspectionDate.ToShortDateString()
        </dd>
        <dt class="col-sm-2">
            Score
        </dt>
        <dd class="col-sm-10">
            @Model.Score
        </dd>
        <dt class="col-sm-2">
            Outcome
        </dt>
        <dd class="col-sm-10">
            @if (Model.Outcome.ToString() == "Fail")
            {
                <span class="badge bg-danger">Fail</span>
            }
            else
            {
                <span class="badge bg-success">Pass</span>
            }
        </dd>
        <dt class="col-sm-2">
            Notes
        </dt>
        <dd class="col-sm-10">
            @Model.Notes
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
