@model oop_s2_2_mvc_76122.Models.Inspection

<h2>Create Inspection</h2>

<form asp-action="Create">

    <div>
        <label>Premises</label>
        <select asp-for="PremisesId">
            @foreach (var p in ViewBag.Premises)
            {
                <option value="@p.Id">@p.Name</option>
            }
        </select>
    </div>

    <div>
        <label>Date</label>
        <input asp-for="InspectionDate" />
    </div>

    <div>
        <label>Score</label>
        <input asp-for="Score" />
    </div>

    <div>
        <label>Outcome</label>
        <input asp-for="Outcome" />
    </div>

    <div>
        <label>Notes</label>
        <input asp-for="Notes" />
    </div>

    <button type="submit">Save</button>

</form>