<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Food Safety</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>

<nav class="navbar navbar-dark bg-dark">
    <div class="container-fluid">

        <a class="navbar-brand" href="/Dashboard">Food Safety</a>

        <div>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <span class="text-white me-3">
                    @User.Identity.Name

                    @if (User.IsInRole("Admin"))
                    {
                        <span class="badge bg-danger">Admin</span>
                    }
                    else if (User.IsInRole("Inspector"))
                    {
                        <span class="badge bg-warning text-dark">Inspector</span>
                    }
                    else if (User.IsInRole("Viewer"))
                    {
                        <span class="badge bg-secondary">Viewer</span>
                    }
                </span>

                <a class="btn btn-light me-2" href="/Dashboard">Dashboard</a>

                @if (User.IsInRole("Admin"))
                {
                    <a class="btn btn-light me-2" href="/Premises">Premises</a>
                }

                @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
                {
                    <a class="btn btn-light me-2" href="/Inspection">Inspections</a>
                    <a class="btn btn-light me-2" href="/FollowUp">FollowUps</a>
                }

                <a class="btn btn-outline-light" href="/Account/Logout">Logout</a>
            }
            else
            {
                <a class="btn btn-outline-light" href="/Account/Login">Login</a>
            }

        </div>

    </div>
</nav>

<div class="container mt-4">
    @RenderBody()
</div>

</body>
</html>